# Kafka Integration Environment Variables
# =========================================
# Configuration for Kafka CDC pipeline and Bronze Ready Emitter

# ---------------------------------------------------------------------------
# Kafka Configuration
# ---------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Dead Letter Queue topic for failed messages
KAFKA_DLQ_TOPIC=dlq-errors

# Max rows per Kafka message (for DataFrame publishing)
KAFKA_MAX_ROWS_PER_MSG=500

# ---------------------------------------------------------------------------
# MinIO Configuration (for Bronze Ready Emitter)
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# Bronze bucket name
BRONZE_BUCKET=syniqai-bronze

# ---------------------------------------------------------------------------
# Database Connection Strings (for CDC Connectors)
# ---------------------------------------------------------------------------

# PostgreSQL
POSTGRES_CONNECTION_STRING=postgresql://username:password@localhost:5432/database

# MariaDB
MARIADB_CONNECTION_STRING=mysql://username:password@localhost:3306/database

# MongoDB
MONGODB_CONNECTION_STRING=mongodb://username:password@localhost:27017/database

# ---------------------------------------------------------------------------
# AWS S3 Configuration (for S3 Connector)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=your-bucket-name

# ---------------------------------------------------------------------------
# Kafka Connect Configuration (for Debezium)
# ---------------------------------------------------------------------------
KAFKA_CONNECT_URL=http://localhost:8083

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
