# ============================================================================
# MongoDB CDC Configuration - Production Environment
# ============================================================================

# -----------------------------------------------------------------------------
# MongoDB Connection Settings
# -----------------------------------------------------------------------------
# Primary MongoDB connection URI
MONGODB_URI=mongodb+srv://connector_user:ConnectorPass123@test.pw8zb01.mongodb.net/?appName=Test

# Database to monitor for CDC
MONGODB_DATABASE=media_db

# Collections to monitor (comma-separated)
# Leave empty to monitor all collections in the database
MONGODB_COLLECTIONS=images_metadata

# Authentication (if required)
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_AUTH_SOURCE=admin

# -----------------------------------------------------------------------------
# CDC Extraction Settings
# -----------------------------------------------------------------------------
# Number of documents per batch (affects Kafka message size)
MONGODB_BATCH_SIZE=1000

# Poll interval in minutes (how often to check for new data)
MONGODB_POLL_INTERVAL_MINUTES=30

# Maximum batches per extraction run (0 = unlimited)
MONGODB_MAX_BATCHES_PER_RUN=0

# Dry run mode (set to true for testing without sending to Kafka)
MONGODB_DRY_RUN=false

# -----------------------------------------------------------------------------
# Kafka Settings
# -----------------------------------------------------------------------------
# Kafka broker addresses
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# Kafka topic prefix (topics will be: airflow.mongodb.<collection_name>)
KAFKA_MONGODB_TOPIC_PREFIX=airflow.mongodb

# Kafka producer settings
KAFKA_COMPRESSION_TYPE=snappy
KAFKA_MAX_REQUEST_SIZE=10485760
KAFKA_BATCH_SIZE=16384
KAFKA_LINGER_MS=10

# -----------------------------------------------------------------------------
# Watermark Persistence
# -----------------------------------------------------------------------------
# Path to watermark storage (JSON file tracking last processed ObjectId)
MONGODB_WATERMARK_FILE=./watermarks/mongodb_watermarks.json

# Backup watermarks to MinIO (set to true for production)
MONGODB_WATERMARK_BACKUP_ENABLED=true

# -----------------------------------------------------------------------------
# MinIO/S3 Settings (for Bronze layer and backups)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_BACKUPS=backups

# -----------------------------------------------------------------------------
# Logging and Monitoring
# -----------------------------------------------------------------------------
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE_PATH=./logs/mongodb_cdc.log

# Enable detailed metrics logging
ENABLE_METRICS=true

# Metrics export interval (seconds)
METRICS_EXPORT_INTERVAL=60

# -----------------------------------------------------------------------------
# Airflow Integration
# -----------------------------------------------------------------------------
# Airflow DAG settings
AIRFLOW_DAG_ID=mongodb_cdc_extraction
AIRFLOW_DAG_SCHEDULE=*/30 * * * *
AIRFLOW_DAG_CATCHUP=false
AIRFLOW_DAG_MAX_ACTIVE_RUNS=1

# Airflow email notifications
AIRFLOW_EMAIL_ON_FAILURE=true
AIRFLOW_EMAIL_ON_RETRY=false
AIRFLOW_ALERT_EMAIL=admin@syniqai.com

# -----------------------------------------------------------------------------
# Performance Tuning
# -----------------------------------------------------------------------------
# MongoDB connection pool size
MONGODB_MAX_POOL_SIZE=50
MONGODB_MIN_POOL_SIZE=10

# MongoDB read preference (primary, primaryPreferred, secondary, etc.)
MONGODB_READ_PREFERENCE=secondaryPreferred

# Query timeout (seconds)
MONGODB_QUERY_TIMEOUT=300

# Parallel extraction worker threads
MONGODB_WORKER_THREADS=4

# -----------------------------------------------------------------------------
# Error Handling
# -----------------------------------------------------------------------------
# Retry configuration
MAX_RETRIES=3
RETRY_DELAY_SECONDS=60
RETRY_EXPONENTIAL_BACKOFF=true

# Dead letter queue for failed messages
KAFKA_DLQ_TOPIC=dlq.mongodb.failures
ENABLE_DLQ=true

# -----------------------------------------------------------------------------
# Health Checks
# -----------------------------------------------------------------------------
# Health check endpoint port
HEALTH_CHECK_PORT=8081

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=30

# -----------------------------------------------------------------------------
# Development/Testing Settings
# -----------------------------------------------------------------------------
# Enable test data seeding
ENABLE_TEST_DATA_SEED=false

# Test data size (number of documents per collection)
TEST_DATA_SIZE=10000

# Test mode (skips production validations)
TEST_MODE=false
