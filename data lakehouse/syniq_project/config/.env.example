# ============================================================
# Syniq Lakehouse - Environment Variables Template
# ============================================================
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Replace placeholder values with real credentials
# 3. Never commit .env to git
# ============================================================

# =========================
# POSTGRESQL (Client DB)
# =========================
POSTGRES_HOST=your-postgres-host.company.com
POSTGRES_PORT=5432
POSTGRES_DB=your_database_name
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_secure_password
POSTGRES_SSL_MODE=require
POSTGRES_SCHEMA=public

# =========================
# MARIADB (On-Premise)
# =========================
MARIADB_HOST=your-mariadb-host.company.com
MARIADB_PORT=3306
MARIADB_DB=your_database_name
MARIADB_USER=your_username
MARIADB_PASSWORD=your_secure_password
MARIADB_SSL_CA=/path/to/ca-cert.pem
MARIADB_CHARSET=utf8mb4

# =========================
# MARIADB CLOUD (SkySQL)
# =========================
MARIADB_CLOUD_HOST=dbpgxxxxxx.mdb0001234.db.skysql.net
MARIADB_CLOUD_PORT=5001
MARIADB_CLOUD_DB=your_cloud_database
MARIADB_CLOUD_USER=your_cloud_username
MARIADB_CLOUD_PASSWORD=your_secure_password
MARIADB_CLOUD_SSL_CA=/path/to/skysql-ca.pem
MARIADB_CLOUD_SSL_VERIFY=true

# =========================
# MONGODB
# =========================
# Connection string format:
# mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DATABASE=your_database_name
MONGODB_AUTH_SOURCE=admin
MONGODB_SSL=true
MONGODB_RETRY_WRITES=true
MONGODB_W=majority

# =========================
# AWS S3
# =========================
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_S3_PREFIX=incoming/
AWS_SESSION_TOKEN=  # Optional: for temporary credentials

# =========================
# MINIO (Local/On-Premise Object Storage)
# =========================
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=syniq-lake
MINIO_SECURE=false
MINIO_REGION=us-east-1

# =========================
# LOGGING & MONITORING
# =========================
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/syniq_ingestion.log
ENABLE_CONSOLE_LOGGING=true

# =========================
# INGESTION SETTINGS
# =========================
DEFAULT_CHUNK_SIZE=100000
MAX_PARALLEL_EXTRACTIONS=3
EXTRACTION_TIMEOUT_SECONDS=3600
ENABLE_SCHEMA_VALIDATION=true