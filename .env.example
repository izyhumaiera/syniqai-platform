# =============================================================================
# SyniqAI Platform — Environment Configuration EXAMPLE
# =============================================================================
# Copy this file to .env and fill in your actual values.
# This file is safe to commit — it contains NO real credentials.

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=syniqai_metadata
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password

# -----------------------------------------------------------------------------
# MinIO Object Storage
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_SECURE=false
MINIO_BRONZE_BUCKET=syniqai-bronze
MINIO_SILVER_BUCKET=syniqai-silver
MINIO_GOLD_BUCKET=syniqai-gold

# -----------------------------------------------------------------------------
# Kafka Configuration
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_BRONZE_READY_TOPIC=bronze-ready
KAFKA_SILVER_READY_TOPIC=silver-ready
KAFKA_DLQ_TOPIC=dlq-errors

# -----------------------------------------------------------------------------
# LLM Configuration
# Providers: openai | azure_openai | local | none
# -----------------------------------------------------------------------------
LLM_PROVIDER=openai
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=sk-YOUR_OPENAI_API_KEY_HERE
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0

# -----------------------------------------------------------------------------
# OpenRouter Configuration (Block 2 — AI Processing Worker)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_KEY_HERE

# -----------------------------------------------------------------------------
# Spark / Java (Windows — set JAVA_HOME to JDK 17)
# -----------------------------------------------------------------------------
JAVA_HOME=C:\Program Files\Eclipse Adoptium\jdk-17.0.18.8-hotspot
