# TSD Media Pipeline - MongoDB Connection Configuration
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file and rename it to: on_prem.env
# 2. Replace the placeholder values below with your actual MongoDB details
# 3. Save the file
# 4. Run the application
#
# IMPORTANT: Never share this file with actual credentials!

# MongoDB Server IP Address or Hostname
MONGO_HOST=YOUR_MONGODB_SERVER_IP_HERE

# MongoDB Port (default is 27017)
MONGO_PORT=27017

# MongoDB Username
MONGO_USER=YOUR_USERNAME_HERE

# MongoDB Password
MONGO_PASS=YOUR_PASSWORD_HERE

# Authentication Database (usually 'admin')
MONGO_AUTH_SOURCE=admin

# Target Database Name
MONGO_DB=media_db
